# Supabase — Project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Auth in the browser (Settings → API Keys → Publishable key, or legacy "anon" JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
# Alternative name if you prefer:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Server-only — Data API (new Secret key or legacy service_role JWT)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public URL of this app. Required in production (Vercel, etc.) for correct invite links and share URLs.
# Do NOT leave this as localhost on a deployed site — invite emails would send users to your laptop.
# Local dev: omit or use http://localhost:3000; production: https://your-domain.com
NEXT_PUBLIC_APP_URL=
# Supabase → Authentication → URL configuration:
# - Site URL: same as production NEXT_PUBLIC_APP_URL (or your primary domain)
# - Redirect URLs: include https://your-domain.com/auth/callback (and local URLs for dev if needed)

# ClickUp — optional OAuth (Settings → Apps → Create app). Redirect URL must match:
# {NEXT_PUBLIC_APP_URL}/api/clickup/callback
# If unset, you can still connect by pasting a personal API token (pk_…) on Integrations.
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
